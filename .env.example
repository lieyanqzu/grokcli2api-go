GROK2API_HOST=0.0.0.0
GROK2API_PORT=8088
GROK2API_LOG_LEVEL=INFO


# 单个请求最多尝试的不同上游账号数量
GROK_RETRY_MAX_ATTEMPTS=3
# 可重试网络错误和上游 5xx 错误的基础退避时间
GROK_RETRY_BASE_DELAY=200ms
# 上游返回 429 且未提供 Retry-After 时，账号进入冷却的时间
GROK_RATE_LIMIT_COOLDOWN=1m
# 上游账号或免费模型额度耗尽后的默认冷却时间
GROK_QUOTA_COOLDOWN=24h
# 会话与上游账号亲和关系的有效时间；hard binding 会哈希化持久保存，soft binding 仅在内存中
GROK_AFFINITY_TTL=1h
# 最多保存的会话亲和关系数量
GROK_AFFINITY_MAX_ENTRIES=100000


# 可选。留空（默认）表示不启用访问控制。设置后，受保护的 API 和上游透传接口
# 必须携带 `Authorization: Bearer <key>`、`x-api-key: <key>` 或
# `api-key: <key>`。OpenAI SDK 客户端会自动将 `api_key` 参数作为 Bearer 令牌发送
# 支持配置多个 Key，可为每个客户端分配独立 Key。
# 每个 Key 还会派生独立的 tenant namespace；不配置 Key 时所有调用方共享 public tenant。

GROK_API_KEYS=key1,key2,key3

# 可选的管理员密钥。设置后启用远程凭证管理接口，并允许在凭证目录为空时启动服务。
# 管理接口仅接受此密钥，不接受上面的普通 API Key。请使用独立的强随机值，
# 并且只通过 HTTPS 和受限网络暴露管理接口。一键部署脚本会自动生成安全随机值。
GROK_ADMIN_KEY=


# 直接放入 Grok CLI auth.json 或兼容凭证，支持旧单凭证、tokens 包装和多 scope 文件。
# 文件支持热加载；刷新时只在文件锁内原子更新目标 scope。state v2 与哈希化 hard affinity
# 也保存在此目录，因此目录必须可写。
GROK_AUTHS_DIR=./auths
# 扫描凭证目录并热加载新增、更新或删除文件的时间间隔
GROK_AUTHS_RELOAD_INTERVAL=30s
# 同时执行 OAuth 令牌刷新的最大并发数
GROK_AUTH_REFRESH_CONCURRENCY=4
# 每个账号允许同时发往上游的最大请求数。超出的请求会等待其他账号或已释放的容量，
GROK_ACCOUNT_MAX_INFLIGHT=16
# 按此时间间隔刷新 state v2 中每个账号的结构化上游模型目录与 ETag。
GROK_MODELS_REFRESH_INTERVAL=6h


# 出站代理
# 支持 http://、https://（CONNECT）、socks5:// 和 socks5h://
# 示例：
#   GROK_PROXY_URL=http://127.0.0.1:8080            # 本地 mitmproxy
#   GROK_PROXY_URL=socks5://user:pass@127.0.0.1:1080
#   GROK_PROXY_URL=http://corp-proxy.internal:3128
# 未设置时，Go 会遵循标准的 HTTP_PROXY、HTTPS_PROXY 和 ALL_PROXY 环境变量

# GROK_PROXY_URL=

# 即使已设置 GROK_PROXY_URL，也可以用逗号分隔主机名或匹配规则来绕过代理
# 匹配规则遵循标准 NO_PROXY 语法，例如 "localhost,*.internal,10.0.0.0/8"
# GROK_NO_PROXY=localhost,127.0.0.1


# 兼容旧版单 Key 配置别名
# GROK_API_KEY=


# ！！！以下配置仅在明确了解本项目以后再修改！！！
# ！！！以下配置仅在明确了解本项目以后再修改！！！
# ！！！以下配置仅在明确了解本项目以后再修改！！！

# Grok CLI 连接的地址
GROK_CHAT_PROXY_BASE_URL=https://cli-chat-proxy.grok.com
GROK_CHAT_PROXY_VERSION=v1
# API Key 账号固定使用运维配置的 xAI API origin，远端模型字段不能覆盖
GROK_XAI_API_BASE_URL=https://api.x.ai
# 流式传输默认使用 identity，避免 gzip 层缓冲较小的 SSE 事件
# 仅在需要兼容性回退时设置为 gzip
GROK_STREAM_COMPRESSION=identity
# 如果上游返回 HTTP 426，并要求更高的最低版本，请更新此值
GROK_CLIENT_VERSION=0.2.102
GROK_CLIENT_SURFACE=tui
# 默认使用非交互的 headless 客户端模式；可选 interactive
GROK_CLIENT_MODE=headless
GROK_CLIENT_IDENTIFIER=grok-shell
GROK_TOKEN_AUTH=xai-grok-cli
# 可选的托管部署标识
# GROK_DEPLOYMENT_ID=
# x-grok-* 请求头配置
GROK_CLIENT_NAME=grok-shell
# 仅可在受控调试环境中关闭 TLS 证书验证
# GROK_TLS_INSECURE_SKIP_VERIFY=false
